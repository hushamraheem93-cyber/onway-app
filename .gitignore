# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Expo ──────────────────────────────────────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts

# ── Native (generated) ────────────────────────────────────────────────────────
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.mobileprovision
/ios
/android

# ── Metro ─────────────────────────────────────────────────────────────────────
.metro-health-check*

# ── Debug logs ────────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Environment / Secrets — NEVER commit these ────────────────────────────────
.env
.env.local
.env.production
.env.staging
.env.test
.env*.local

# Firebase service account key files (any naming pattern)
FIREBASE_SERVICE_ACCOUNT
service-account.json
service-account*.json
*-service-account.json
firebase-adminsdk*.json
*.serviceaccount.json
firestore-credentials.json

# TLS / SSL certificates and private keys
*.pem
*.key
*.crt
*.cert
*.p7b
*.pfx

# Other credential files
*.credentials
credentials.json
client_secret*.json

# ── Build outputs (regenerated — never commit) ────────────────────────────────
/server_dist/
/static-build/
/admin-dist/

# ── Exports / backups / scratch ───────────────────────────────────────────────
/exports/
/review-export/
/attached_assets/
*.zip

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Misc ──────────────────────────────────────────────────────────────────────
app-example
scripts/backups/
scripts/reports/
tests/reports/
