entrypoint = "README.md"
modules = ["nodejs-22", "python-3.11", "postgresql-16"]

[nix]
channel = "stable-24_05"
packages = ["vips", "zip"]

# DEPLOYMENT (permanent, always-on URL — no Shell, no Metro, no Expo Go):
# Build BOTH the web UI (static-build) AND the server bundle, then run the server
# which serves static-build on $PORT. Previously this only ran `server:build`, so a
# deployment came up with NO web UI to serve. Now `Deploy` yields a working app URL.
[deployment]
deploymentTarget = "vm"
build = ["sh", "-c", "npm run expo:static:build && npm run server:build"]
run = ["sh", "-c", "node server_dist/index.js"]

[env]
PORT = "5000"

[agent]
stack = "EXPO"
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

# RUN (dev preview in the Webview — reliable, one click):
# 1) free the ports, 2) build the web UI once — scripts/build.js spawns and kills
#    its OWN Metro, so it is fully self-contained, 3) start the API server (dev mode)
#    on port 5000, which serves static-build. We deliberately DROPPED `expo:dev`: it
#    ran a second Metro on 8081 that collided with the build's internal Metro and left
#    the Webview empty. Sequential + no port race = the app shows every time.
# Dev mode (server:dev) keeps the 000000 test OTP working for quick sign-in.
[[workflows.workflow]]
name = "Project"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 8081/tcp 8082/tcp 2>/dev/null; sleep 1; rm -rf static-build; npm run expo:static:build && npm run server:dev"
waitForPort = 5000

[userenv]

[userenv.shared]
GOOGLE_CLIENT_ID = "116297695107-hq1eclup48in29qd1an5vv165nlbgf0a.apps.googleusercontent.com"
ADMIN_GOOGLE_EMAIL = "husham.raheem93@gmail.com"
ALLOWED_ORIGINS = "https://admin.onway.iq,https://www.admin.onway.iq"
ALLOW_DEV_OTP = "true"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 9005
externalPort = 3000
