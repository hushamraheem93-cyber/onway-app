rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
//  OnWay — Firestore Security Rules
//  Last updated: 2026-06-26
//
//  Architecture note:
//  ──────────────────
//  ALL mutations (create / update / delete) happen exclusively through the
//  Express backend using Firebase Admin SDK, which bypasses these rules.
//  These rules therefore protect against:
//    • Direct client-side writes using the public Firebase config
//    • Unauthorized reads of sensitive data via client SDK
//    • Future accidental direct-read code paths
//
//  Access model:
//  ─────────────
//  PUBLIC READ     — browsable product/store data (no auth required)
//  BACKEND ONLY    — sensitive user, order, driver, financial data
//  DEFAULT DENY    — anything not explicitly listed → denied
// ═══════════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── DEFAULT: deny everything not explicitly allowed ────────────────────
    match /{document=**} {
      allow read, write: if false;
    }


    // ══════════════════════════════════════════════════════════════════════
    //  PUBLIC READ-ONLY collections
    //  (client app displays this data before user logs in)
    // ══════════════════════════════════════════════════════════════════════

    // Product categories (grid on home screen)
    match /categories/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Home-screen banners and offer carousels
    match /banners/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Delivery areas and fees (shown during checkout)
    match /deliveryAreas/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Vendor / store listings (restaurants, pharmacies, etc.)
    match /vendors/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Products inside vendor stores
    match /vendorProducts/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Legacy product collection (used alongside vendorProducts)
    match /products/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // App-wide settings: delivery fee config, minimum order thresholds
    match /appSettings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Alternate casing used in some code paths
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Promotional sections: Best Sellers, Featured, Discounts
    match /promotionalSections/{docId} {
      allow read: if true;
      allow write: if false;
    }


    // ══════════════════════════════════════════════════════════════════════
    //  BACKEND-ONLY — all writes AND reads via Admin SDK only
    //  (any direct client access → denied)
    // ══════════════════════════════════════════════════════════════════════

    // ── User data ──────────────────────────────────────────────────────────
    // Contains: name, phone, push token, saved addresses, loyalty points
    match /users/{docId} {
      allow read, write: if false;
    }

    match /addresses/{docId} {
      allow read, write: if false;
    }

    // ── Orders ────────────────────────────────────────────────────────────
    // Contains: items, prices, customer PII, delivery address
    match /orders/{docId} {
      allow read, write: if false;
    }

    // ── Driver system ─────────────────────────────────────────────────────
    match /drivers/{docId} {
      allow read, write: if false;
    }

    match /driverWallets/{docId} {
      allow read, write: if false;
    }

    match /walletHistory/{docId} {
      allow read, write: if false;
    }

    match /driverActivityLog/{docId} {
      allow read, write: if false;
    }

    match /driverCompletedOrders/{docId} {
      allow read, write: if false;
    }

    match /driverActivities/{docId} {
      allow read, write: if false;
    }

    // ── Batch delivery ────────────────────────────────────────────────────
    match /delivery_batches/{docId} {
      allow read, write: if false;
    }

    match /delivery_logs/{docId} {
      allow read, write: if false;
    }

    // ── Promo codes ───────────────────────────────────────────────────────
    match /promoCodes/{docId} {
      allow read, write: if false;
    }

    match /promoUsage/{docId} {
      allow read, write: if false;
    }

    match /promoUsageHistory/{docId} {
      allow read, write: if false;
    }

    // ── Notifications & push tokens ───────────────────────────────────────
    match /pushTokens/{docId} {
      allow read, write: if false;
    }

    match /notifications/{docId} {
      allow read, write: if false;
    }

    match /adminNotifications/{docId} {
      allow read, write: if false;
    }

    match /adminAlerts/{docId} {
      allow read, write: if false;
    }

    match /vendorNotifications/{docId} {
      allow read, write: if false;
    }

    // ── Support chat ──────────────────────────────────────────────────────
    match /supportChats/{docId} {
      allow read, write: if false;
    }

    match /support_chats/{docId} {
      allow read, write: if false;
    }

    // ── Admin ─────────────────────────────────────────────────────────────
    match /adminConfig/{docId} {
      allow read, write: if false;
    }

    // ── Financial / Settlement ─────────────────────────────────────────────
    // settlementLedger: read by vendor/driver client SDK via onSnapshot (VendorWalletScreen).
    // Document IDs are in the format "vendor:{uuid}" or "driver:{phone}" — obscure enough
    // to prevent guessing. Writes are Admin SDK only (backend-enforced, rules redundant).
    match /settlementLedger/{docId} {
      allow read: if true;   // client onSnapshot (VendorWalletScreen / DriverEarningsScreen)
      allow write: if false; // Admin SDK bypasses; explicit deny for client writes
    }

    match /settlements/{docId} {
      allow read, write: if false;
    }

    match /settlementRequests/{docId} {
      allow read, write: if false;
    }

    match /settlementPayments/{docId} {
      allow read, write: if false;
    }

    match /driverFinancialAccounts/{docId} {
      allow read, write: if false;
    }

    match /driverTransactions/{docId} {
      allow read, write: if false;
    }

    match /promoUsageHistory/{docId} {
      allow read, write: if false;
    }

    // ── Internal / cache ──────────────────────────────────────────────────
    match /productImageHashes/{docId} {
      allow read, write: if false;
    }
  }
}
